# =============================================================================
# TEMPLATE for the .env file. Copy this to ".env" and fill in real values:
#     cp .env.example .env        (macOS/Linux)
#     Copy-Item .env.example .env (Windows PowerShell)
# This file IS committed to git so teammates know which variables are required.
# Never put real secrets here.
# =============================================================================

# ----- Application -----
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ----- Database -----
DATABASE_URL="postgresql://univers:univers_dev_password@localhost:5432/univers?schema=public"

# ----- JWT (JSON Web Tokens) -----
# Generate each secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- Admin panel (the /admin calendar editor) -----
# A single shared login protects the staff calendar editor (no per-user roles).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="univers-admin-change-me"
# Signs the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-a-long-random-string"

# ----- File uploads (the /admin documents library) -----
# Where uploaded files (e.g. the «دروس ارائه‌شده» PDF) are stored on disk, and the
# per-file size cap in MB. Both are optional; these are the defaults.
UPLOAD_DIR="uploads"
MAX_UPLOAD_MB=20

# ----- Web Push (VAPID) -----
# Sign browser push notifications. All optional — if unset, OS push is disabled
# (the in-app real-time notifications still work). Generate a key pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The PUBLIC key is also served to the PWA via GET /push/public-key.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
