// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// The "client" generator tells Prisma to build a fully type-safe database
// client from the models below. Prisma 7 generates it into our own source tree
// (so it gets compiled with the app) instead of hiding it inside node_modules.
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"

  // Emit CommonJS-compatible code. NestJS compiles to CommonJS by default, but
  // Prisma 7 defaults to ESM and would generate `import.meta` calls that crash
  // at runtime under CommonJS. This keeps the generated client compatible.
  moduleFormat = "cjs"
}

// The datasource is the database connection. The actual URL is supplied in
// prisma.config.ts (which reads DATABASE_URL from .env), keeping secrets out
// of this schema file.
datasource db {
  provider = "postgresql"
}

// =============================================================================
// MODELS — each "model" becomes a table in the database.
// =============================================================================

// A registered user of the application.
model User {
  // Primary key. cuid() generates a short, collision-resistant, URL-safe id
  // (safer to expose publicly than a guessable auto-incrementing number).
  id String @id @default(cuid())

  // The login identifier. @unique means the database enforces no duplicates.
  email String @unique

  // The password, stored ONLY as a bcrypt hash — never in plain text.
  password String

  // Optional display name.
  name String?

  // bcrypt hash of the user's current refresh token. Lets us validate refresh
  // requests and revoke sessions (set to null on logout). Nullable = logged out.
  hashedRefreshToken String?

  // Timestamps Prisma maintains automatically.
  createdAt DateTime @default(now()) // set once, when the row is created
  updatedAt DateTime @updatedAt // updated every time the row changes

  // ---- Relations to per-student features ----
  profile           Profile? // extended profile the student fills in (1-1)
  courses           Course[] // the user's weekly-schedule courses
  scheduleSettings  ScheduleSettings? // reminder + week-parity preferences
  pushSubscriptions PushSubscription[] // devices this user is logged in on

  // Store this model in a table literally named "users" (lowercase plural is a
  // common SQL convention), rather than the default "User".
  @@map("users")
}

// =============================================================================
// PROFILE (اطلاعات حساب کاربری)
// The extended profile a student fills in themselves. Kept as a SEPARATE 1-1
// table (like ScheduleSettings) rather than piling columns onto User, so auth
// stays lean and future profile fields land here without touching login code.
//
// EVERY field is optional: the student fills the profile in gradually, and the
// PWA awards "points" for each completed field (see profile/profile.constants.ts
// for the weights). Clearing a field on the PWA sets it back to null here.
//
// The display NAME lives on User.name (it's used by register + the JWT flow), so
// it is intentionally NOT duplicated here.
// =============================================================================
model Profile {
  id String @id @default(cuid())

  // One row per user (@unique turns this 1-N relation into 1-1).
  // Cascade = deleting the user removes their profile too.
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ---- Personal (اطلاعات فردی) ----
  phone String? // شماره تماس

  // کد ملی. @unique so two accounts can't claim the same national id (many nulls
  // are allowed — Postgres treats NULLs as distinct). We catch the unique-clash
  // in the service and return a friendly Persian error.
  nationalId String? @unique

  // تاریخ تولد, stored as a Jalali date STRING ("۱۳۸۰/۰۵/۱۲" normalised to
  // "1380/05/12"). It's only ever displayed, never computed on, so a plain string
  // avoids all Jalali↔Gregorian conversion headaches.
  birthDate String?

  gender   String? // "male" | "female" (validated in the DTO)
  province String? // استان
  city     String? // شهر

  // ---- Academic (اطلاعات تحصیلی) ----
  // These used to be hard-coded mock data in the PWA; now the student enters and
  // owns them (this app has no university SIS to import them from).
  studentId String? @unique // شماره دانشجویی
  major     String? // رشته تحصیلی
  faculty   String? // دانشکده
  degree    String? // "associate" | "bachelor" | "master" | "phd" (validated)
  entryYear Int? // سال ورود — a Jalali year, e.g. 1403
  advisor   String? // استاد راهنما

  // ---- Avatar (تصویر پروفایل) ----
  // Only lightweight metadata lives here; the image BYTES live on disk under a
  // random name in uploads/avatars (same "files on disk, metadata in DB" pattern
  // the documents feature uses). null = using the initials fallback.
  avatarStoredName String?
  avatarMimeType   String?

  // ---- Bio & emergency (درباره و تماس اضطراری) ----
  bio            String? // درباره من
  emergencyName  String? // نام مخاطب اضطراری
  emergencyPhone String? // شماره مخاطب اضطراری
  telegram       String? // شناسه پیام‌رسان (تلگرام)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// =============================================================================
// WEEKLY SCHEDULE (برنامه هفتگی)
// Each student builds their own class timetable in the PWA. A Course is the
// subject itself (name / professor / colour); its CourseSessions are the actual
// weekly meetings (e.g. ساختمان داده on Saturday AND Monday = one course, two
// sessions). Splitting them keeps the course's colour and name consistent
// everywhere and lets the reminder job target individual meetings.
// =============================================================================

model Course {
  id String @id @default(cuid())

  // The owning student. Cascade = deleting a user removes their schedule too.
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The course name in Persian, e.g. «ساختمان داده‌ها».
  name String

  // Optional professor name, e.g. «دکتر رضایی».
  professor String?

  // A palette slug (e.g. "teal", "violet") the PWA maps to Tailwind classes.
  // Validated in the DTO against a known set — plain string so adding a colour
  // later needs NO migration.
  color String @default("teal")

  // The weekly meetings of this course. Cascade is declared on the session side,
  // so deleting a course removes its sessions.
  sessions CourseSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // We always fetch courses by their owner, so index that column.
  @@index([userId])
  @@map("courses")
}

// One weekly meeting of a course, e.g. "Saturday 10:00–11:30 in کلاس ۲۰۴".
model CourseSession {
  id String @id @default(cuid())

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Day of the university week: 0 = شنبه … 5 = پنجشنبه. (Friday has no classes,
  // so 6 is never stored; the DTO validates the range.)
  dayOfWeek Int

  // Class times as MINUTES from midnight, Tehran local time (e.g. 10:00 → 600).
  // Storing integers (not "10:00" strings) makes the reminder job's time math
  // and overlap/ordering comparisons trivial. The API converts to "HH:mm".
  startMinute Int
  endMinute   Int

  // Optional location, e.g. «کلاس ۲۰۴» or «آز. نرم‌افزار».
  room String?

  // Session kind: "theory" (نظری) | "practical" (عملی). Plain string validated
  // in the DTO, so a future kind needs no migration.
  type String @default("theory")

  // Week parity: "all" = every week, "odd" = فرد only, "even" = زوج only.
  // Many courses meet on alternating weeks in Iranian universities.
  parity String @default("all")

  // The reminder job looks up "today's sessions" constantly, so index the day
  // together with the course.
  @@index([courseId])
  @@index([dayOfWeek])
  @@map("course_sessions")
}

// Per-student preferences for the weekly schedule. Kept OUT of the User model so
// auth stays lean and future schedule options land here without touching users.
model ScheduleSettings {
  id String @id @default(cuid())

  // One row per user (@unique turns this 1-N relation into 1-1).
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Master switch for class push reminders.
  remindersEnabled Boolean @default(true)

  // How many minutes before class start the reminder fires (e.g. 30).
  reminderLeadMinutes Int @default(30)

  // Week-parity reference: the date of a SATURDAY that starts an ODD (فرد) week.
  // Parity of any later week = weeks-elapsed since this date, mod 2. The student
  // sets it by simply telling us "this week is فرد/زوج" — the API converts that
  // to the right Saturday. null = parity untracked (all sessions treated as due).
  // @db.Date keeps it date-only so timezones can never shift it.
  oddWeekAnchor DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("schedule_settings")
}

// =============================================================================
// ACADEMIC CALENDAR (تقویم آموزشی)
// University staff edit these rows from the /admin panel each term — no code
// changes needed. A "Semester" groups the dated events shown on the calendar.
// =============================================================================

// One academic term, e.g. "نیمسال دوم ۱۴۰۴-۱۴۰۵". Exactly one row is marked
// active at a time; the public API (and the PWA) always read the active one.
model Semester {
  id String @id @default(cuid())

  // The heading shown above the calendar, in Persian.
  title String

  // Optional smaller line under the title (e.g. "مصوب شورای آموزشی دانشگاه").
  subtitle String?

  // Only ONE semester should be active at a time. We enforce that in code
  // (activating one deactivates the others) rather than in the schema, because
  // SQL can't easily express "at most one row may be true".
  isActive Boolean @default(false)

  // The events belonging to this semester. The cascade is declared on the event
  // side, so deleting a semester also removes its events.
  events CalendarEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("semesters")
}

// A single dated row of the calendar, e.g. "انتخاب واحد ورودی ۴۰۲ و ماقبل".
model CalendarEvent {
  id String @id @default(cuid())

  // Which semester this row belongs to.
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  // The event name in Persian, e.g. "شروع کلاس‌ها".
  title String

  // A coarse category that drives the colour + filter chips in the PWA. We keep
  // it a plain string (validated in the DTO against a known set) instead of a
  // Prisma enum, so adding a category later needs NO migration.
  // Known values: registration | addDrop | exams | academic | holiday
  category String

  // OPTIONAL entry-year cohort this row targets — free text, because the
  // groupings change between terms (e.g. "ورودی ۴۰۲ و ماقبل", "ورودی ۴۰۳ و ۴۰۴").
  // null = applies to everyone.
  cohort String?

  // The event day. We store a REAL calendar date (not the free text "۱۴ بهمن"):
  // staff pick it with a Jalali date-picker in the admin and we convert
  // Jalali → Gregorian on save. Storing an absolute date is what lets us COMPUTE
  // the status (past / current / upcoming) and a countdown automatically.
  // @db.Date keeps it date-only, so a server timezone can never shift it a day.
  startDate DateTime @db.Date

  // For multi-day entries — a range (the exam period) or two consecutive days
  // (حذف تکدرس on ۱۷ & ۱۸). null = a single-day event.
  endDate DateTime? @db.Date

  // Optional longer explanation shown when a card is expanded.
  description String?

  // Tie-breaker for ordering rows that fall on the same date.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // We almost always fetch events by their semester, so index that column.
  @@index([semesterId])
  @@map("calendar_events")
}

// =============================================================================
// DOCUMENTS (اسناد و فایل‌ها)
// A small, GENERIC file-library feature. University staff upload a file (e.g. the
// Golestan «دروس ارائه‌شده» PDF) from the /admin panel; students view or download
// it on the PWA — no code changes per term. Files are grouped by a "category"
// slug (e.g. "courses"); within each category exactly one row is marked active
// (the one students see) and the rest form a browsable archive.
//
// The file BYTES live on disk (in the uploads/ folder); only this lightweight
// METADATA row lives in the database. Stuffing big binaries into Postgres bloats
// backups and memory, so the standard pattern is "files on disk, metadata in DB".
// =============================================================================
model Document {
  id String @id @default(cuid())

  // Which page/feature this file belongs to. A free-text slug (validated in the
  // DTO against a known set) rather than a Prisma enum, so adding a new category
  // later needs NO migration. Known values: courses | chart | forms ...
  category String

  // The Persian title shown to students, e.g. «دروس ارائه‌شده نیمسال دوم ۱۴۰۴-۱۴۰۵».
  title String

  // Optional smaller note shown under the title (e.g. a source or date line).
  description String?

  // ---- File metadata ----

  // The name we saved the file under on disk (a random cuid + extension). We
  // never reuse the user's original name for the on-disk path — it could collide
  // with another upload or contain unsafe path characters.
  storedName String

  // The original name the staff member's file had, e.g. "download.pdf". Shown in
  // the UI and used as the suggested filename when a student downloads it.
  originalName String

  // The file's MIME type, e.g. "application/pdf"; lets the download endpoint send
  // the correct Content-Type header.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // OPTIONAL page count, typed by staff at upload (e.g. 81). We deliberately do
  // NOT parse the PDF on the server (fragile + an extra dependency); a manual
  // number is simpler and gives a nice «۸۱ صفحه» label. null = unknown.
  pageCount Int?

  // Only ONE document per category is active at a time. Enforced in code
  // (activating one deactivates the others IN THE SAME CATEGORY), because SQL
  // can't easily express "at most one true row per category".
  isActive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // We always fetch documents by their category, so index that column.
  @@index([category])
  @@map("documents")
}

// =============================================================================
// NEWS / ANNOUNCEMENTS (اخبار و اطلاعیه‌ها)
// Staff post these from /admin; the PWA shows them in the home-page carousel AND
// pushes new ones to every open client in real time over SSE (Server-Sent
// Events) — see NewsService.stream(). No per-term code changes.
// =============================================================================
model News {
  id String @id @default(cuid())

  // The headline shown on the card.
  title String

  // A coarse category that drives the badge (and future filtering). Plain string,
  // validated in the DTO against a known set, so adding one needs no migration.
  // Known values: academic | services | student | general
  category String

  // The announcement text — the card's body / description.
  body String

  // OPTIONAL "read more" URL (an internal route or an external link). null = none.
  link String?

  // ---- Cover image (تصویر شاخص) ----
  // OPTIONAL hero image shown at the top of the news detail page. Only lightweight
  // metadata lives here; the image BYTES live on disk under a random name in the
  // shared uploads/ folder — the same "files on disk, metadata in DB" pattern the
  // documents feature (and the profile avatar) use. null = no cover.
  coverStoredName String?
  coverMimeType   String?

  // The downloadable files staff attach to this item (بخشنامه‌ها، فرم‌ها، …).
  // Cascade is declared on the attachment side, so deleting a news item removes
  // its attachment rows (the on-disk files are unlinked in NewsService.remove).
  attachments NewsAttachment[]

  // Drafts (isPublished=false) are hidden from the public API; pinned items sort
  // ahead of the rest in the carousel.
  isPublished Boolean @default(true)
  pinned      Boolean @default(false)

  // When the item counts as "published" — the date shown on the card. Defaults to
  // creation time, but kept SEPARATE from createdAt so it can be back/post-dated
  // later without muddling the audit timestamps.
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by pinned + publishedAt.
  @@index([isPublished, pinned, publishedAt])
  @@map("news")
}

// One file attached to a news item. Mirrors Document's file-metadata columns:
// the BYTES live on disk under a random name in the shared uploads/ folder, only
// this lightweight metadata row lives in the database. A news item can have many
// (PDFs, images, Office docs); staff add/remove them from the /admin panel.
model NewsAttachment {
  id String @id @default(cuid())

  // The owning news item. Cascade = deleting the news removes its attachment rows.
  newsId String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)

  // The name we saved the file under on disk (a random cuid + extension). We never
  // reuse the user's original name for the on-disk path — it could collide with
  // another upload or contain unsafe path characters.
  storedName String

  // The original name the staff member's file had, e.g. "بخشنامه.pdf". Shown in the
  // UI and used as the suggested filename when a student downloads it.
  originalName String

  // The file's MIME type, e.g. "application/pdf"; lets the download endpoint send
  // the correct Content-Type header and the UI pick a file-type icon.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is well under 2GB). Shown
  // formatted (e.g. «۴٫۲ مگابایت»).
  size Int

  // Tie-breaker so attachments render in the order staff uploaded them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // We always fetch attachments by their news item, so index that column.
  @@index([newsId])
  @@map("news_attachments")
}

// =============================================================================
// EDUCATIONAL CHART (چارت آموزشی)
// The curriculum roadmap library. Students pick a DEPARTMENT (رشته) and download
// its chart PDFs — and a department can carry MORE THAN ONE PDF (e.g. one per
// curriculum era: «قبل ۱۴۰۳» vs «۱۴۰۳ به بعد»). That one-department-to-many-files
// shape is exactly the News → NewsAttachment pattern, so we model it the same way
// (parent row + child file rows) rather than the Document model's single-active
// -file-per-category shape, which doesn't fit here.
//
// University staff manage both levels from the /admin panel (add/edit/reorder
// departments and upload/remove their PDFs) — no per-term code changes. The PDF
// BYTES live on disk under a random name in the shared uploads/ folder; only this
// lightweight METADATA lives in the database ("files on disk, metadata in DB").
// =============================================================================
model ChartDepartment {
  id String @id @default(cuid())

  // A stable, URL-safe key the PWA maps to its department colour token
  // (--color-<slug>) and uses as a React list key. @unique so the seed can
  // upsert by it and two departments can't collide. e.g. "computer".
  slug String @unique

  // The Persian department name shown on the card, e.g. «مهندسی کامپیوتر».
  title String

  // The emoji shown in the card's avatar, e.g. "💻". A plain string (staff type
  // any emoji), with a book fallback so a blank never renders an empty circle.
  icon String @default("📚")

  // A colour slug the PWA maps to a design-system token. Validated in the service
  // against a known set (CHART_DEPARTMENT_COLORS) — plain string, so re-theming
  // needs NO migration. e.g. "computer" → text-computer / bg-computer/10.
  color String @default("computer")

  // Manual ordering of the department list (lower = higher up). Staff reorder in
  // the admin; ties fall back to title.
  sortOrder Int @default(0)

  // Hidden departments stay in the DB (and keep their files) but are dropped from
  // the public API — handy while staff are still preparing a department's charts.
  isPublished Boolean @default(true)

  // The downloadable chart PDFs of this department. Cascade is declared on the
  // file side, so deleting a department removes its file rows (the on-disk PDFs
  // are unlinked in ChartService.removeDepartment).
  files ChartFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by sortOrder.
  @@index([isPublished, sortOrder])
  @@map("chart_departments")
}

// One chart PDF belonging to a department. Mirrors NewsAttachment's file-metadata
// columns: the BYTES live on disk under a random name in the shared uploads/
// folder, only this lightweight metadata row lives in the database.
model ChartFile {
  id String @id @default(cuid())

  // The owning department. Cascade = deleting the department removes its files.
  departmentId String
  department   ChartDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  // The Persian title shown for this specific chart, e.g.
  // «کارشناسی مهندسی نرم‌افزار قبل ۱۴۰۳».
  title String

  // OPTIONAL free-text era/entry-year tag rendered as a small pill on the card,
  // e.g. «قبل ۱۴۰۳» or «۱۴۰۳ به بعد». null = no badge.
  badge String?

  // The name we saved the file under on disk (a random cuid + extension). We never
  // reuse the user's filename for the on-disk path — it could collide with another
  // upload or contain unsafe path characters.
  storedName String

  // The original name the staff member's file had, e.g. «چارت-نرم‌افزار.pdf». Shown
  // in the admin and used as the suggested filename when a student downloads it.
  originalName String

  // The file's MIME type (always application/pdf here); lets the download endpoint
  // send the correct Content-Type header.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // Tie-breaker so a department's charts render in the order staff arranged them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // We always fetch files by their department, so index that column.
  @@index([departmentId])
  @@map("chart_files")
}

// =============================================================================
// PHONE BOOK (شماره‌های دانشگاه)
// The university phone directory students browse under /phone-list. It used to be
// hard-coded in the PWA (lib/phone-data.ts); now staff manage it from /admin so a
// changed extension or a whole new unit needs NO code change. The shape is the
// same one-parent-to-many-children as چارت آموزشی (ChartDepartment → ChartFile),
// but the children are plain contact rows, so there are NO files on disk here —
// everything lives in these two tables.
// =============================================================================

// One heading in the directory, e.g. «معاونت آموزشی» — a group of related numbers.
model ContactGroup {
  id String @id @default(cuid())

  // The Persian heading shown above the group's numbers, e.g. «امور دانشجویی».
  title String

  // An icon KEY (not an emoji): a stable slug the PWA maps to a HugeIcons line
  // icon (see lib/phone-meta.ts), keeping the current monochrome look. Validated
  // in the service against a known set (CONTACT_GROUP_ICONS) — a plain string, so
  // re-theming needs NO migration. e.g. "library" → Book02Icon.
  icon String @default("phone")

  // Manual ordering of the group list (lower = higher up). Staff reorder in the
  // admin; ties fall back to title.
  sortOrder Int @default(0)

  // Hidden groups stay in the DB (and keep their numbers) but drop out of the
  // public API — handy while staff are still preparing a group's contacts.
  isPublished Boolean @default(true)

  // The phone numbers in this group. Cascade is declared on the contact side, so
  // deleting a group removes its contact rows.
  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by sortOrder.
  @@index([isPublished, sortOrder])
  @@map("contact_groups")
}

// One number in the directory, e.g. «اداره ثبت‌نام و امتحانات».
model Contact {
  id String @id @default(cuid())

  // The owning group. Cascade = deleting the group removes its contacts.
  groupId String
  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // The unit / person name shown on the row, e.g. «میز امانت».
  name String

  // The phone number as a plain string (kept exactly as staff typed it — leading
  // zeros, short codes like «۱۱۵», etc.). The PWA formats it for display and uses
  // it verbatim in the `tel:` link, so we never normalise or coerce it to a number.
  phone String

  // OPTIONAL internal extension, shown as «داخلی ۲۱۰». null = no extension.
  ext String?

  // OPTIONAL one-line note shown under the name, e.g. working hours or a role.
  // null = none.
  note String?

  // OPTIONAL contact email, rendered as a mailto link. null = none.
  email String?

  // Tie-breaker so a group's numbers render in the order staff arranged them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // We always fetch contacts by their group, so index that column.
  @@index([groupId])
  @@map("contacts")
}

// =============================================================================
// GROUPS & CHANNELS (گروه‌ها)
// The directory of joinable university groups/channels students browse under
// /groups. It used to be hard-coded in the PWA (lib/data/groups-data.ts); now
// staff manage it from /admin so a new channel or a changed invite link needs NO
// code change. It's a THREE-level tree — one level deeper than the phone book —
// because a single group can advertise SEVERAL ways to join:
//
//   GroupCategory (e.g. «کانال‌های رسمی»)
//     └─ Group      (e.g. «انجمن علمی کامپیوتر» — one card)
//          └─ GroupLink (a join option: a link, a copyable id, or a QR image)
//
// The QR images are the only files on disk here; everything else is plain rows.
// =============================================================================

// One heading in the directory, e.g. «کانال‌های رسمی» — a group of related cards.
// Staff create/rename/reorder these freely (free-form, like phone-book groups).
model GroupCategory {
  id String @id @default(cuid())

  // The Persian heading shown above the category's cards, e.g. «گروه‌های کلاسی».
  title String

  // Manual ordering of the category list (lower = higher up). Staff reorder in the
  // admin; ties fall back to title.
  sortOrder Int @default(0)

  // Hidden categories stay in the DB (and keep their groups) but drop out of the
  // public API — handy while staff are still preparing a category's contents.
  isPublished Boolean @default(true)

  // The group/channel cards in this category. Cascade is declared on the group
  // side, so deleting a category removes its groups (and their links).
  groups Group[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by sortOrder.
  @@index([isPublished, sortOrder])
  @@map("group_categories")
}

// One joinable group/channel — the shape the PWA renders as a card.
model Group {
  id String @id @default(cuid())

  // The owning category. Cascade = deleting a category removes its groups.
  categoryId String
  category   GroupCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // The Persian name of the group/channel, e.g. «اطلاع‌رسانی آموزش دانشگاه».
  title String

  // OPTIONAL one/two-line description shown under the title. null = none.
  description String?

  // A short, FREE-TEXT platform badge staff type themselves, e.g. «تلگرام»،
  // «واتساپ»، «ایتا»، «بله»، «اینستاگرام». Rendered as a small pill on the card.
  // We deliberately keep it free text (not an enum/icon key) so staff can label a
  // group with any messenger without a code change. null = no badge shown.
  platform String?

  // Manual ordering of the cards within a category (lower = higher up).
  sortOrder Int @default(0)

  // Hidden groups stay in the DB (and keep their links) but drop out of the public
  // API — handy while a group is still being set up.
  isPublished Boolean @default(true)

  // The ways to join this group (invite links, copyable ids, QR images). Cascade
  // is declared on the link side, so deleting a group removes its link rows (the
  // on-disk QR images are unlinked in GroupsService.removeGroup).
  links GroupLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public tree fetches groups by their category, so index that column.
  @@index([categoryId])
  @@map("groups")
}

// One way to join a group. A group can carry several (a main channel + a backup,
// a channel plus its discussion group, …). Its `kind` decides which field holds
// the payload:
//   • "link"   → `url`    (a clickable invite/join URL)
//   • "handle" → `handle` (a copyable @username or invite CODE — not every join
//                          is a URL, so this is tap-to-copy on the PWA)
//   • "qr"     → an uploaded QR image (qrStoredName/qrMimeType), streamed inline.
model GroupLink {
  id String @id @default(cuid())

  // The owning group. Cascade = deleting a group removes its links.
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Which kind of join option this row is: "link" | "handle" | "qr". A plain
  // string validated in the service against a known set (GROUP_LINK_KINDS), so a
  // future kind needs NO migration.
  kind String @default("link")

  // OPTIONAL short label shown on the button/row, e.g. «کانال اصلی» or «گروه پرسش
  // و پاسخ». null = the PWA falls back to a default label for the kind.
  label String?

  // The join URL — set for kind="link" (e.g. https://t.me/example). null otherwise.
  url String?

  // The copyable handle/code — set for kind="handle" (e.g. «@university» or an
  // invite code). Shown with a copy button on the PWA. null otherwise.
  handle String?

  // ---- QR image (for kind="qr") ----
  // Only lightweight metadata lives here; the image BYTES live on disk under a
  // random name in the shared uploads/ folder (same "files on disk, metadata in
  // DB" pattern as news/chart). null = this row isn't a QR (or has no image yet).
  qrStoredName String?
  qrMimeType   String?

  // Tie-breaker so a group's join options render in the order staff arranged them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // We always fetch links by their group, so index that column.
  @@index([groupId])
  @@map("group_links")
}

// =============================================================================
// WEB PUSH SUBSCRIPTIONS
// One row per browser/device that opted in to OS push notifications. The PWA
// registers its PushSubscription here; PushService encrypts and sends to every
// row when news is published, and prunes any the push service reports as gone.
// =============================================================================
model PushSubscription {
  id String @id @default(cuid())

  // OPTIONAL owner. Set when the subscribe request carried a valid access token
  // (the PWA re-registers on every open, so this tracks the CURRENT login on the
  // device). null = an anonymous device that only gets broadcast news pushes.
  // Personal notifications (class reminders) go only to a user's own devices.
  // SetNull (not Cascade): deleting a user detaches the device, keeps news push.
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // The push-service URL the browser gave us. @unique so re-subscribing the same
  // device UPSERTS this row instead of creating a duplicate.
  endpoint String @unique

  // The browser's public key + auth secret from its PushSubscription. We need
  // both to encrypt the payload so only that browser can decrypt it.
  p256dh String
  auth   String

  // Optional — which browser/device this is, handy when debugging.
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The reminder job fetches a user's devices, so index the owner column.
  @@index([userId])
  @@map("push_subscriptions")
}

// =============================================================================
// DORMITORY (خوابگاه)
// A self-contained hub for the student dorm, managed by dorm staff from /admin.
// It replaced the old static «حذف و اضافه» page. Four independent pieces make up
// the hub, deliberately kept in their own tables so each is edited on its own and
// none blocks the others:
//
//   • DormAnnouncement — the اطلاعیه‌های خوابگاه feed. Modelled exactly like News
//     (cover + attachments + pinned + publish) and, like News, it fans a new item
//     out as an OS Web Push AND an in-app SSE toast/bell entry. It is a SEPARATE
//     model from News on purpose: dorm posts stay on the dorm page and never mix
//     into the home carousel or the main /news feed.
//   • DormInfoItem — the قوانین و مقررات and امکانات و ساعات کاری lists. One table
//     serves BOTH, keyed by a `section` slug ("rules" | "facilities"), the same
//     "one generic table, a slug per list" idea used elsewhere for categories.
//   • DormForm — the فرم‌ها و مدارک library: a flat list of downloadable files
//     (تسویه‌حساب، تعهدنامه، …). "Files on disk, metadata in DB", like Document —
//     but a plain published list, since dorm forms are all available at once
//     rather than one-active-per-category.
// =============================================================================

// One dorm announcement/notice — the shape the PWA renders as a card and, when
// freshly published, pushes to every device. Mirrors the News model field-for-
// field so the service/DTO/admin logic can follow the proven news pattern.
model DormAnnouncement {
  id String @id @default(cuid())

  // The headline shown on the card.
  title String

  // A coarse category that drives the badge. Plain string, validated in the DTO
  // against a known set, so adding one needs no migration.
  // Known values: general | facility | financial | event | maintenance
  category String

  // The announcement text — the card's body / description (Markdown).
  body String

  // OPTIONAL "read more" URL (an internal route or an external link). null = none.
  link String?

  // ---- Cover image (تصویر شاخص) ----
  // OPTIONAL hero image; only metadata lives here, the bytes live on disk under a
  // random name in the shared uploads/ folder (same pattern as News). null = none.
  coverStoredName String?
  coverMimeType   String?

  // The downloadable files staff attach (بخشنامه، فرم، …). Cascade is declared on
  // the attachment side, so deleting an announcement removes its attachment rows
  // (the on-disk files are unlinked in DormService.removeAnnouncement).
  attachments DormAnnouncementAttachment[]

  // Drafts (isPublished=false) are hidden from the public API; pinned items sort
  // ahead of the rest in the feed.
  isPublished Boolean @default(true)
  pinned      Boolean @default(false)

  // When the item counts as "published" — the date shown on the card. Kept
  // SEPARATE from createdAt so it can be back/post-dated without muddling audit
  // timestamps (again mirroring News).
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by pinned + publishedAt.
  @@index([isPublished, pinned, publishedAt])
  @@map("dorm_announcements")
}

// One file attached to a dorm announcement. Mirrors NewsAttachment: the BYTES
// live on disk under a random name in the shared uploads/ folder, only this
// lightweight metadata row lives in the database.
model DormAnnouncementAttachment {
  id String @id @default(cuid())

  // The owning announcement. Cascade = deleting it removes its attachment rows.
  announcementId String
  announcement   DormAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  // The name we saved the file under on disk (a random cuid + extension). We never
  // reuse the user's filename for the on-disk path — it could collide or contain
  // unsafe path characters.
  storedName String

  // The original name the staff member's file had, e.g. «تعهدنامه.pdf». Shown in
  // the UI and used as the suggested filename when a student downloads it.
  originalName String

  // The file's MIME type; lets the download endpoint send the right Content-Type
  // and the UI pick a file-type icon.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // Tie-breaker so attachments render in the order staff uploaded them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // We always fetch attachments by their announcement, so index that column.
  @@index([announcementId])
  @@map("dorm_announcement_attachments")
}

// One row of the قوانین و مقررات OR امکانات و ساعات کاری list. A single table
// serves both, keyed by `section`; the two lists have the same shape (a heading
// line + an optional detail line), so there's no reason to split them.
model DormInfoItem {
  id String @id @default(cuid())

  // Which list this row belongs to: "rules" | "facilities". A plain string
  // validated in the service against a known set (DORM_INFO_SECTIONS), so adding
  // a future section (e.g. "faq") needs NO migration.
  section String

  // The main line: the rule text, or the facility name (e.g. «رختشویخانه»).
  title String

  // OPTIONAL secondary line: a rule's elaboration, or a facility's hours/notes
  // (e.g. «همه‌روزه ۸ تا ۲۲»). null = show just the title.
  detail String?

  // Manual ordering within a section (lower = higher up). Staff reorder in the
  // admin; ties fall back to createdAt.
  sortOrder Int @default(0)

  // Hidden rows stay in the DB but drop out of the public API.
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by section + isPublished and orders by sortOrder.
  @@index([section, isPublished, sortOrder])
  @@map("dorm_info_items")
}

// One downloadable dorm form/document — a flat published list (unlike Document's
// one-active-per-category shape, dorm forms are all available at once). The file
// BYTES live on disk under a random name in the shared uploads/ folder; only this
// metadata lives in the database.
model DormForm {
  id String @id @default(cuid())

  // The Persian title shown to students, e.g. «فرم تسویه‌حساب خوابگاه».
  title String

  // OPTIONAL smaller note shown under the title. null = none.
  description String?

  // The name we saved the file under on disk (a random cuid + extension).
  storedName String

  // The original filename; the suggested name when a student downloads it.
  originalName String

  // The file's MIME type; lets the download endpoint send the right Content-Type.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // Manual ordering of the list (lower = higher up). Ties fall back to createdAt.
  sortOrder Int @default(0)

  // Hidden forms stay in the DB but drop out of the public API.
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by sortOrder.
  @@index([isPublished, sortOrder])
  @@map("dorm_forms")
}

// =============================================================================
// FOOD (تغذیه)
// The غذای هفته page could not integrate with the university's food-reservation
// system (no API access), so the section was rebuilt as an information hub run
// by cafeteria staff from /admin/food:
//
//   • FoodMenuFile — the weekly menu as a staff-uploaded file (image or PDF).
//     Staff upload a new file each week; the public API serves the NEWEST
//     published row as "this week's menu", older rows stay as history. "Files on
//     disk, metadata in DB", exactly like DormForm.
//   • FoodAnnouncement — the اطلاعیه‌های تغذیه feed (self-service closures, price
//     changes, menu updates …). Modelled exactly like DormAnnouncement/News:
//     cover + attachments + pinned + publish, and a new item fans out as an OS
//     Web Push AND an in-app SSE toast/bell entry. Kept SEPARATE from News on
//     purpose: food posts stay on the food page and never mix into /news.
//
// The page's third piece — the nearby-places map — has NO table here on purpose:
// places come live from OpenStreetMap (Overpass API) through a caching proxy in
// FoodService, so there is nothing for staff to maintain.
// =============================================================================

// One food announcement/notice — the shape the PWA renders as a card and, when
// freshly published, pushes to every device. Mirrors DormAnnouncement field-for-
// field so the service/DTO/admin logic can follow the proven pattern.
model FoodAnnouncement {
  id String @id @default(cuid())

  // The headline shown on the card.
  title String

  // A coarse category that drives the badge. Plain string, validated in the DTO
  // against a known set, so adding one needs no migration.
  // Known values: general | menu | hours | event | closure
  category String

  // The announcement text — the card's body / description (Markdown).
  body String

  // OPTIONAL "read more" URL (an internal route or an external link). null = none.
  link String?

  // ---- Cover image (تصویر شاخص) ----
  // OPTIONAL hero image; only metadata lives here, the bytes live on disk under a
  // random name in the shared uploads/ folder (same pattern as News). null = none.
  coverStoredName String?
  coverMimeType   String?

  // The downloadable files staff attach (منوی کامل، اطلاعیه رسمی، …). Cascade is
  // declared on the attachment side, so deleting an announcement removes its
  // attachment rows (the on-disk files are unlinked in FoodService).
  attachments FoodAnnouncementAttachment[]

  // Drafts (isPublished=false) are hidden from the public API; pinned items sort
  // ahead of the rest in the feed.
  isPublished Boolean @default(true)
  pinned      Boolean @default(false)

  // When the item counts as "published" — the date shown on the card. Kept
  // SEPARATE from createdAt so it can be back/post-dated without muddling audit
  // timestamps (again mirroring News).
  publishedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public list filters by isPublished and orders by pinned + publishedAt.
  @@index([isPublished, pinned, publishedAt])
  @@map("food_announcements")
}

// One file attached to a food announcement. Mirrors DormAnnouncementAttachment:
// the BYTES live on disk under a random name in the shared uploads/ folder, only
// this lightweight metadata row lives in the database.
model FoodAnnouncementAttachment {
  id String @id @default(cuid())

  // The owning announcement. Cascade = deleting it removes its attachment rows.
  announcementId String
  announcement   FoodAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  // The name we saved the file under on disk (a random cuid + extension). We never
  // reuse the user's filename for the on-disk path — it could collide or contain
  // unsafe path characters.
  storedName String

  // The original name the staff member's file had, e.g. «منوی-مهر.pdf». Shown in
  // the UI and used as the suggested filename when a student downloads it.
  originalName String

  // The file's MIME type; lets the download endpoint send the right Content-Type
  // and the UI pick a file-type icon.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // Tie-breaker so attachments render in the order staff uploaded them.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  // We always fetch attachments by their announcement, so index that column.
  @@index([announcementId])
  @@map("food_announcement_attachments")
}

// One uploaded weekly menu file (image or PDF). The public API serves the NEWEST
// published row as the current منوی هفته; older rows remain as browsable history
// in the admin panel until staff delete them.
model FoodMenuFile {
  id String @id @default(cuid())

  // OPTIONAL Persian label naming the menu's week, e.g. «هفتهٔ سوم مهر».
  // null = the card just says «منوی این هفته».
  weekLabel String?

  // The name we saved the file under on disk (a random cuid + extension).
  storedName String

  // The original filename; the suggested name when a student downloads it.
  originalName String

  // The file's MIME type; the PWA renders images inline and offers PDFs as a
  // view/download card.
  mimeType String

  // File size in bytes (Int is ample — the upload cap is ~20MB). Shown formatted.
  size Int

  // Hidden rows stay in the DB but drop out of the public API — lets staff stage
  // next week's menu before publishing it.
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The public read is "newest published", so index exactly that.
  @@index([isPublished, createdAt])
  @@map("food_menu_files")
}
