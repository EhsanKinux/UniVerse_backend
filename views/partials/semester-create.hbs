<form method="post" action="/admin/semesters" class="row">
  <div class="field" style="flex:2 1 240px">
    <label for="sem-title">عنوان نیمسال</label>
    <input type="text" id="sem-title" name="title" placeholder="مثلاً: نیمسال دوم ۱۴۰۴-۱۴۰۵" required />
  </div>
  <div class="field" style="flex:2 1 240px">
    <label for="sem-subtitle">زیرعنوان (اختیاری)</label>
    <input type="text" id="sem-subtitle" name="subtitle" placeholder="مثلاً: مصوب شورای آموزشی دانشگاه" />
  </div>
  <div class="field" style="flex:0 0 auto">
    <button type="submit" class="btn">ساخت نیمسال</button>
  </div>
</form>
