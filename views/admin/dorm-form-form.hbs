{{> head}}
<div class="container">
  <div class="card">
    <h2>بارگذاری فرم جدید خوابگاه</h2>

    {{#if error}}<div class="alert alert-error">{{error}}</div>{{/if}}

    <form method="post" action="{{action}}" enctype="multipart/form-data">
      <div class="row">
        <div class="field">
          <label>عنوان فرم</label>
          <input type="text" name="title" value="{{item.title}}" placeholder="مثلاً «فرم تسویه‌حساب خوابگاه»" required />
        </div>
        <div class="field" style="flex:0 1 120px">
          <label>ترتیب نمایش</label>
          <input type="text" name="sortOrder" value="{{item.sortOrder}}" placeholder="0" />
        </div>
      </div>

      <div class="field">
        <label>توضیح (اختیاری)</label>
        <input type="text" name="description" value="{{item.description}}" placeholder="توضیح کوتاه دربارهٔ فرم" />
      </div>

      <div class="field">
        <label>فایل</label>
        <input type="file" name="file" accept=".pdf,image/*,.doc,.docx,.xls,.xlsx,.ppt,.pptx" required />
        <div class="hint">PDF، عکس یا اسناد Office، حداکثر ۲۰ مگابایت.</div>
      </div>

      <div class="row" style="gap:20px">
        <label class="check"><input type="checkbox" name="isPublished" checked /> نمایش در اپ</label>
      </div>

      <div style="margin-top:18px;display:flex;gap:8px">
        <button class="btn" type="submit">بارگذاری</button>
        <a class="btn btn-ghost" href="/admin/dormitory">انصراف</a>
      </div>
    </form>
  </div>
</div>
{{> foot}}
