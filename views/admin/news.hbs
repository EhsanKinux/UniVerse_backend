{{> head}}
<div class="container">
  <div class="card">
    <div class="toolbar">
      <h2 style="margin:0">اخبار و اطلاعیه‌ها</h2>
      <a class="btn btn-sm" href="/admin/news/new">+ خبر جدید</a>
    </div>

    {{#if hasItems}}
    <table>
      <thead>
        <tr><th>عنوان</th><th>دسته</th><th>تاریخ</th><th>وضعیت</th><th></th></tr>
      </thead>
      <tbody>
        {{#each items}}
        <tr>
          <td>
            <strong>{{title}}</strong>
            {{#if pinned}}<span class="pill">📌 سنجاق‌شده</span>{{/if}}
          </td>
          <td>{{categoryLabel}}</td>
          <td class="muted">{{date}}</td>
          <td>
            {{#if isPublished}}<span class="badge current">منتشرشده</span>{{else}}<span class="badge past">پیش‌نویس</span>{{/if}}
          </td>
          <td>
            <div class="actions">
              <form method="post" action="/admin/news/{{id}}/toggle" class="inline">
                <button class="btn btn-ghost btn-sm" type="submit">{{#if isPublished}}لغو انتشار{{else}}انتشار{{/if}}</button>
              </form>
              <a class="btn btn-ghost btn-sm" href="/admin/news/{{id}}/edit">ویرایش</a>
              <form method="post" action="/admin/news/{{id}}/delete" class="inline"
                    onsubmit="return confirm('حذف این خبر؟');">
                <button class="btn btn-danger btn-sm" type="submit">حذف</button>
              </form>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <div class="empty">هنوز خبری ثبت نشده است. برای شروع، «خبر جدید» را بزنید.</div>
    {{/if}}
  </div>
</div>
{{> foot}}
