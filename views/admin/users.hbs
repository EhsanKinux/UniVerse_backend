{{> head}}
<div class="container">
  <div class="card">
    <div class="toolbar">
      <h2 style="margin:0">کاربران ثبت‌نام‌شده <span class="muted" style="font-weight:400;font-size:14px">({{total}})</span></h2>
      <form method="get" action="/admin/users" class="row" style="margin:0;gap:8px;align-items:center">
        <input type="text" name="q" value="{{search}}" placeholder="جستجوی ایمیل یا نام…" style="width:220px" />
        <button class="btn btn-sm" type="submit">جستجو</button>
        {{#if search}}<a class="btn btn-ghost btn-sm" href="/admin/users">حذف فیلتر</a>{{/if}}
      </form>
    </div>

    {{#if hasUsers}}
    <table>
      <thead>
        <tr><th>کاربر</th><th>شماره دانشجویی</th><th>تکمیل پروفایل</th><th>تاریخ عضویت</th><th></th></tr>
      </thead>
      <tbody>
        {{#each users}}
        <tr>
          <td>
            <div style="display:flex;align-items:center;gap:10px">
              {{#if avatarUrl}}
              <img src="{{avatarUrl}}" alt="" style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:1px solid var(--line)" />
              {{else}}
              <span style="width:34px;height:34px;border-radius:50%;background:#eef2ff;color:#4f46e5;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:13px">{{name.[0]}}</span>
              {{/if}}
              <div style="min-width:0">
                <div style="font-weight:600">{{name}}</div>
                <div class="muted" dir="ltr" style="font-size:12px;text-align:right">{{email}}</div>
              </div>
            </div>
          </td>
          <td dir="ltr" style="text-align:right">{{studentId}}</td>
          <td style="min-width:150px">
            <div style="display:flex;align-items:center;gap:8px">
              <span style="flex:1;height:7px;background:#eef2f7;border-radius:999px;overflow:hidden">
                <span style="display:block;height:100%;width:{{percent}}%;background:var(--brand);border-radius:999px"></span>
              </span>
              <span class="muted" style="font-size:12px;width:34px">٪{{percent}}</span>
            </div>
          </td>
          <td class="muted">{{joined}}</td>
          <td>
            <div class="actions">
              <a class="btn btn-ghost btn-sm" href="/admin/users/{{id}}">مشاهده</a>
              <form method="post" action="/admin/users/{{id}}/delete" class="inline"
                    onsubmit="return confirm('حذف کامل این کاربر و همه اطلاعاتش؟ این عمل قابل بازگشت نیست.');">
                <button class="btn btn-danger btn-sm" type="submit">حذف</button>
              </form>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    {{#if showPagination}}
    <div class="toolbar" style="margin-top:16px;justify-content:center;gap:14px">
      {{#if hasPrev}}<a class="btn btn-ghost btn-sm" href="{{prevUrl}}">← قبلی</a>{{else}}<span class="btn btn-ghost btn-sm" style="opacity:.4">← قبلی</span>{{/if}}
      <span class="muted" style="font-size:13px">صفحه {{page}} از {{totalPages}}</span>
      {{#if hasNext}}<a class="btn btn-ghost btn-sm" href="{{nextUrl}}">بعدی →</a>{{else}}<span class="btn btn-ghost btn-sm" style="opacity:.4">بعدی →</span>{{/if}}
    </div>
    {{/if}}

    {{else}}
    <div class="empty">
      {{#if search}}کاربری با این مشخصات یافت نشد.{{else}}هنوز کاربری ثبت‌نام نکرده است.{{/if}}
    </div>
    {{/if}}
  </div>
</div>
{{> foot}}
