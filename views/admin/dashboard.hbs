{{> head}}
<div class="container">
  {{#unless hasSemesters}}
    <div class="card">
      <h2>هنوز نیمسالی ساخته نشده است</h2>
      <p class="muted">برای شروع، نخستین نیمسال تحصیلی را بسازید، سپس رویدادهای آن را اضافه کنید.</p>
      {{> semester-create}}
    </div>
  {{else}}
    <div class="card">
      <h2>نیمسال‌ها</h2>
      <ul class="sem-list">
        {{#each semesters}}
        <li class="sem-item {{#if isActive}}active{{/if}}">
          <div>
            <a href="/admin?semester={{id}}"><strong>{{title}}</strong></a>
            {{#if isActive}}<span class="badge current">فعال</span>{{/if}}
            <span class="muted"> — {{count}} رویداد</span>
          </div>
          <div class="actions">
            {{#unless isActive}}
            <form method="post" action="/admin/semesters/{{id}}/activate" class="inline">
              <button class="btn btn-ghost btn-sm" type="submit">فعال‌سازی</button>
            </form>
            {{/unless}}
            <form method="post" action="/admin/semesters/{{id}}/delete" class="inline"
                  onsubmit="return confirm('حذف این نیمسال و همهٔ رویدادهایش؟');">
              <button class="btn btn-danger btn-sm" type="submit">حذف</button>
            </form>
          </div>
        </li>
        {{/each}}
      </ul>
      <details style="margin-top:14px">
        <summary class="muted" style="cursor:pointer">+ افزودن نیمسال جدید</summary>
        <div style="margin-top:12px">{{> semester-create}}</div>
      </details>
    </div>

    <div class="card">
      <div class="toolbar">
        <div>
          <h2 style="margin:0">رویدادهای «{{selected.title}}»</h2>
          {{#if selected.subtitle}}<div class="muted">{{selected.subtitle}}</div>{{/if}}
        </div>
        <a class="btn btn-sm" href="/admin/semesters/{{selectedId}}/events/new">+ رویداد جدید</a>
      </div>

      {{#if events.length}}
      <table>
        <thead>
          <tr>
            <th>عنوان</th><th>ورودی</th><th>دسته</th><th>تاریخ</th><th>وضعیت</th><th></th>
          </tr>
        </thead>
        <tbody>
          {{#each events}}
          <tr>
            <td><strong>{{title}}</strong></td>
            <td>{{#if cohort}}<span class="pill">{{cohort}}</span>{{else}}<span class="muted">—</span>{{/if}}</td>
            <td>{{lookup ../categoryLabels category}}</td>
            <td>{{weekday}} {{dateLabel}}</td>
            <td><span class="badge {{status}}">{{lookup ../statusLabels status}}</span></td>
            <td>
              <div class="actions">
                <a class="btn btn-ghost btn-sm" href="/admin/events/{{id}}/edit">ویرایش</a>
                <form method="post" action="/admin/events/{{id}}/delete" class="inline"
                      onsubmit="return confirm('حذف این رویداد؟');">
                  <button class="btn btn-danger btn-sm" type="submit">حذف</button>
                </form>
              </div>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{else}}
      <div class="empty">هنوز رویدادی برای این نیمسال ثبت نشده است.</div>
      {{/if}}
    </div>
  {{/unless}}
</div>
{{> foot}}
